# Local caches and virtualenvs
.ansible/
.ansible-lint-cache/
.pytest_cache/
.venv/
ansible/.ansible/
ansible/.ansible-lint-cache/
.DS_Store

# Local secrets and live inventories never belong in the public repo
ansible/.vault_pass
ansible/inventories/personal/

# Local archives and release artifacts
*.tgz
*.tar.gz
*.tar

# Terraform local state and secrets
terraform/**/.terraform/
terraform/**/*.tfstate
terraform/**/*.tfstate.*
terraform/**/*.tfvars
terraform/**/*.tfvars.json
terraform/**/crash.log
terraform/**/openclaw-origin-ca.crt.pem
terraform/**/openclaw-origin-ca.key.pem

# Ansible retry files
*.retry
